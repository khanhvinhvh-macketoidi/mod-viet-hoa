{
    "compilerOptions":  {
                            "target":  "ES2017",
                            "lib":  [
                                        "dom",
                                        "dom.iterable",
                                        "esnext"
                                    ],
                            "allowJs":  true,
                            "skipLibCheck":  true,
                            "strict":  true,
                            "noEmit":  true,
                            "esModuleInterop":  true,
                            "module":  "esnext",
                            "moduleResolution":  "bundler",
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "jsx":  "react-jsx",
                            "incremental":  true,
                            "plugins":  [
                                            {
                                                "name":  "next"
                                            }
                                        ],
                            "paths":  {
                                          "@/*":  [
                                                      "./src/*"
                                                  ]
                                      }
                        },
    "include":  [
                    "next-env.d.ts",
                    "**/*.ts",
                    "**/*.tsx",
                    ".next/types/**/*.ts",
                    ".next/dev/types/**/*.ts",
                    "**/*.mts"
                ],
    "exclude":  [
                    "node_modules",
                    ".next",
                    "_backup_*",
                    "**/_backup_*/**",
                    "backup_*",
                    "**/backup_*/**",
                    "backups",
                    "**/backups/**",
                    "mod-library-backups",
                    "**/mod-library-backups/**",
                    "src/lib/backup",
                    "src/lib/backup/**",
                    "**/backup/**",
                    "**/*.backup.ts",
                    "**/*.bak.ts"
                ]
}
